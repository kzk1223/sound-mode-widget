<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- マナーモード変更に必要な権限 -->
    <uses-permission android:name="android.permission.ACCESS_NOTIFICATION_POLICY" />

    <!-- フォアグラウンドサービス（着信モード監視用） -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- 端末再起動後にサービスを再開 -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Android 13+ 通知表示権限 -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_volume_normal"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.SoundModeWidget">

        <!-- メインActivity（権限リクエスト用） -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.SoundModeWidget">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ウィジェットプロバイダー -->
        <receiver
            android:name=".SoundModeWidgetProvider"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="info.nwp.soundmodewidget.ACTION_TOGGLE" />
                <action android:name="info.nwp.soundmodewidget.ACTION_REFRESH" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/sound_mode_widget_info" />
        </receiver>

        <!-- 端末再起動後の復帰レシーバー（BOOT_COMPLETED は暗黙ブロードキャスト例外） -->
        <receiver
            android:name=".BootCompletedReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!-- 着信モード変更を動的レシーバーで監視するフォアグラウンドサービス -->
        <service
            android:name=".RingerModeObserverService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Monitors ringer mode changes to keep home screen widget in sync" />
        </service>

    </application>

</manifest>
