<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp"
    android:background="#FAFAFA">

    <ImageView
        android:id="@+id/iv_icon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_volume_normal"
        android:contentDescription="アイコン" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="マナーモード切替ウィジェット"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#333333" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="タップで 通常 → バイブ → サイレント を切替"
        android:textSize="14sp"
        android:textColor="#666666"
        android:gravity="center" />

    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="権限を確認中…"
        android:textSize="14sp"
        android:gravity="center" />

    <Button
        android:id="@+id/btn_grant_permission"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="サイレントモード権限を許可する"
        android:textAllCaps="false" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="使い方:\nホーム画面を長押し → ウィジェット →\n「マナーモード切替」を選択"
        android:textSize="13sp"
        android:textColor="#999999"
        android:gravity="center"
        android:lineSpacingExtra="4dp" />

</LinearLayout>
